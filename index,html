<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wish-Jar Pro Max</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">

<style>

body{
font-family:Poppins;
margin:0;
min-height:100vh;
background:linear-gradient(135deg,#89f7fe,#66a6ff,#fbc2eb);
background-size:400% 400%;
animation:bg 12s ease infinite;
}

@keyframes bg{
0%{background-position:0% 50%}
50%{background-position:100% 50%}
100%{background-position:0% 50%}
}

.container{
max-width:900px;
margin:40px auto;
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 15px 30px rgba(0,0,0,.3)
}

.section{
background:#f7f7f7;
padding:20px;
border-radius:15px;
margin:15px 0
}

input,textarea,select,button{
width:100%;
padding:10px;
margin:6px 0;
border-radius:8px;
border:1px solid #ccc
}

button{
background:#2575fc;
color:white;
border:none;
cursor:pointer
}

button:hover{opacity:.8}

.hidden{display:none}

.tabs{
display:flex;
gap:10px;
margin-bottom:15px
}

.tabs button{background:#eee;color:black}
.tabs button.active{background:#2575fc;color:white}

img{max-width:100%;border-radius:10px;margin-top:10px}

</style>
</head>

<body>

<div class="container">

<h1 align="center">🌟 Wish Jar 🌟</h1>

<!-- AUTH -->

<div id="authBox">

<div class="section" id="loginBox">

<h3>Đăng nhập</h3>

<input id="loginUser" placeholder="Username">
<input id="loginPass" type="password">

<button onclick="login()">Đăng nhập</button>

<p>
<a href="#" onclick="showRegister()">Đăng ký</a> |
<a href="#" onclick="showRecover()">Quên mật khẩu</a>
</p>

</div>

<div class="section hidden" id="registerBox">

<h3>Đăng ký</h3>

<input id="regUser" placeholder="Username">
<input id="regPass" type="password">

<div id="questions"></div>

<button onclick="register()">Tạo</button>
<button onclick="showLogin()">Quay lại</button>

</div>

<div class="section hidden" id="recoverBox">

<h3>Khôi phục</h3>

<input id="recUser" placeholder="Username">

<div id="recQuestions"></div>

<input id="newPass" type="password">

<button onclick="recover()">Khôi phục</button>

</div>

</div>

<!-- APP -->

<div id="appBox" class="hidden">

<button onclick="logout()">Đăng xuất</button>

<div class="tabs">

<button id="tabAdd" class="active" onclick="showTab('add')">➕ Thêm</button>
<button id="tabRandom" onclick="showTab('random')">🎲 Lắc</button>
<button id="tabList" onclick="showTab('list')">📚 Danh sách</button>

</div>

<!-- ADD -->

<div id="tab-add">

<div class="section">

<textarea id="note" placeholder="Nhập kỷ niệm..."></textarea>

<select id="mood">
<option>😊</option>
<option>😔</option>
<option>😡</option>
<option>😌</option>
</select>

</div>

<!-- IMAGE -->

<div class="section">

<h3>📷 Ảnh</h3>

<input type="file" id="imageInput" accept="image/*">

<img id="previewImg" class="hidden">

</div>

<div class="section">

<button onclick="addMemory()">💾 Lưu</button>

</div>

</div>

<!-- RANDOM -->

<div id="tab-random" class="hidden">

<div class="section">

<button onclick="shake()">Lắc hũ</button>

<div id="randomBox"></div>

</div>

</div>

<!-- LIST -->

<div id="tab-list" class="hidden">

<div class="section">

<div id="memoryList"></div>

</div>

</div>

</div>

</div>

<script>

/* DATA */

let users=JSON.parse(localStorage.getItem("users"))||{};
let currentUser=localStorage.getItem("currentUser");

/* QUESTIONS */

const questionList=[
"Bạn thân?",
"Món thích?",
"Biệt danh?",
"Ca sĩ thích?",
"Trường cũ?",
"Thành phố mơ?"
];

/* HASH */

async function hash(t){
let b=await crypto.subtle.digest("SHA-256",new TextEncoder().encode(t));
return [...new Uint8Array(b)].map(x=>x.toString(16).padStart(2,"0")).join("");
}

/* UI */

function showLogin(){
loginBox.classList.remove("hidden");
registerBox.classList.add("hidden");
recoverBox.classList.add("hidden");
}

function showRegister(){
showLogin();
loginBox.classList.add("hidden");
registerBox.classList.remove("hidden");
loadQuestions();
}

function showRecover(){
showLogin();
loginBox.classList.add("hidden");
recoverBox.classList.remove("hidden");
recQuestions.innerHTML="";
recoverStep = 0;
}

function showApp(){
authBox.classList.add("hidden");
appBox.classList.remove("hidden");
loadList();
}

function showTab(n){

document.querySelectorAll("[id^='tab-']").forEach(x=>x.classList.add("hidden"));
document.getElementById("tab-"+n).classList.remove("hidden");

document.querySelectorAll(".tabs button").forEach(b=>b.classList.remove("active"));
document.getElementById("tab"+n[0].toUpperCase()+n.slice(1)).classList.add("active");
}

/* REGISTER */

function loadQuestions(){

questions.innerHTML="";

questionList.forEach((q,i)=>{

questions.innerHTML+=`
<div>
<input type="checkbox" id="q${i}"> ${q}<br>
<input id="a${i}">
</div>
`;

});
}

async function register(){

let u=regUser.value.trim();
let p=regPass.value;

if(!u||!p)return alert("Thiếu");

if(users[u])return alert("Tồn tại");

let qa=[];

for(let i=0;i<questionList.length;i++){

if(document.getElementById("q"+i).checked){

let a=document.getElementById("a"+i).value;

if(!a)return alert("Thiếu");

qa.push({q:questionList[i],a:await hash(a)});
}
}

if(qa.length<2)return alert("Chọn ≥2 câu");

users[u]={pass:await hash(p),qa,memories:[]};

save();

alert("OK");

showLogin();
}

/* LOGIN */

async function login(){

let u=loginUser.value.trim();
let p=loginPass.value;

if(!users[u])return alert("Sai");

if(await hash(p)!=users[u].pass)return alert("Sai");

currentUser=u;

localStorage.setItem("currentUser",u);

showApp();
}

/* RECOVER FIX */

let recoverStep = 0;

async function recover(){

let u = recUser.value.trim();

if(!u) return alert("Nhập username");

if(!users[u]) return alert("Không tồn tại");

let qs = users[u].qa;

/* STEP 1 */

if(recoverStep === 0){

recQuestions.innerHTML="";

qs.slice(0,2).forEach((x,i)=>{

recQuestions.innerHTML+=`
<div>
${x.q}<br>
<input id="ra${i}">
<input type="hidden" id="rh${i}" value="${x.a}">
</div>
`;

});

recoverStep = 1;

alert("Trả lời câu hỏi");

return;
}

/* STEP 2 */

if(recoverStep === 1){

for(let i=0;i<2;i++){

let ans = document.getElementById("ra"+i).value;

if(!ans) return alert("Chưa đủ câu trả lời");

let h = await hash(ans);

if(h != document.getElementById("rh"+i).value){
return alert("Sai câu trả lời");
}
}

if(!newPass.value){
return alert("Nhập mật khẩu mới");
}

users[u].pass = await hash(newPass.value);

save();

alert("Khôi phục thành công!");

recoverStep = 0;

recUser.value="";
newPass.value="";
recQuestions.innerHTML="";

showLogin();
}

}

/* IMAGE PREVIEW */

imageInput.onchange=()=>{

let f=imageInput.files[0];

if(!f)return;

let r=new FileReader();

r.onload=()=>{

previewImg.src=r.result;
previewImg.classList.remove("hidden");
};

r.readAsDataURL(f);
};

/* MEMORY */

function addMemory(){

let t=note.value.trim();

if(!t)return alert("Thiếu nội dung");

let f=imageInput.files[0];

if(f){

let r=new FileReader();

r.onload=()=>saveMemory(t,mood.value,r.result);

r.readAsDataURL(f);

}else saveMemory(t,mood.value,null);
}

function saveMemory(text,mood,img){

users[currentUser].memories.push({

text,
mood,
date:new Date().toLocaleDateString(),
image:img

});

save();

note.value="";
imageInput.value="";

previewImg.classList.add("hidden");

loadList();

alert("Đã lưu");
}

/* RANDOM */

function shake(){

let list=users[currentUser].memories;

if(!list.length)return randomBox.innerHTML="Trống";

let m=list[Math.floor(Math.random()*list.length)];

let html=`${m.mood} ${m.text}<br>${m.date}`;

if(m.image)html+=`<img src="${m.image}">`;

randomBox.innerHTML=html;
}

/* LIST */

function loadList(){

memoryList.innerHTML="";

users[currentUser].memories.forEach(m=>{

let d=document.createElement("div");

d.className="section";

let html=`${m.mood} ${m.text}<br>${m.date}`;

if(m.image)html+=`<img src="${m.image}">`;

d.innerHTML=html;

memoryList.appendChild(d);
});
}

/* SAVE */

function save(){
localStorage.setItem("users",JSON.stringify(users));
}

/* LOGOUT */

function logout(){
localStorage.removeItem("currentUser");
location.reload();
}

/* AUTO */

if(currentUser&&users[currentUser])showApp();

loadQuestions();

</script>

</body>
</html>
